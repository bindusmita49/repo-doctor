# ── Secrets ──────────────────────────────────────────────────────────────────
# NEVER commit real credentials — only .env.example belongs in source control
.env

# ── Python cache & bytecode ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Build & distribution ──────────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg
MANIFEST

# ── IDE / editor artefacts ───────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Testing & coverage ───────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── ADK session data ──────────────────────────────────────────────────────────
# ADK writes local session/state files during development
__pycache__/
.adk/
session.db
*.db

# ── Local analysis cache ───────────────────────────────────────────────────────
# Results are cached here to avoid burning Gemini API quota during development.
# Contains no secrets — but is local/ephemeral data, not meant for source control.
analysis_cache.json
